{
  "name": "notebooklm-omni-bridge",
  "displayName": "NotebookLM Omni-Bridge",
  "version": "0.2.0",
  "description": "將網頁內容傳送到 NotebookLM",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@plasmohq/storage": "^1.9.0",
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "plasmo": "^0.90.0",
    "typescript": "^5.3.0"
  },
  "manifest": {
    "permissions": [
      "storage",
      "activeTab",
      "scripting",
      "sidePanel",
      "contextMenus",
      "notifications"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
