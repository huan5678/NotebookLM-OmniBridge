{
  "name": "notebooklm-omni-bridge",
  "displayName": "NotebookLM Omni-Bridge",
  "version": "0.2.0",
  "description": "__MSG_ext_description__",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build && cp offscreen.html offscreen.js build/chrome-mv3-prod/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "autoprefixer": "^10.4.27",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.0",
    "postcss": "^8.5.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@plasmohq/storage": "^1.9.0",
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "plasmo": "^0.90.0",
    "typescript": "^5.3.0"
  },
  "manifest": {
    "default_locale": "zh_TW",
    "permissions": [
      "storage",
      "cookies",
      "offscreen",
      "activeTab",
      "scripting",
      "sidePanel",
      "contextMenus",
      "notifications"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
