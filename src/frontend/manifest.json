{
  "manifest_version": 3,
  "name": "NotebookLM Omni-Bridge",
  "version": "0.1.0",
  "description": "将网页内容传送到 NotebookLM 的 Chrome 扩展",
  "permissions": [
    "storage",
    "identity",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "oauth2": {
    "client_id": "Extension-provided",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/drive.metadata.readonly"
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_side_panel": "side-panel.html"
  },
  "side_panel": {
    "default_path": "side-panel.html"
  }
}
