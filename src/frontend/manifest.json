{
  "manifest_version": 3,
  "name": "NotebookLM Omni-Bridge",
  "version": "0.1.0",
  "description": "將網頁內容傳送到 NotebookLM 的 Chrome 擴充功能",
  "permissions": [
    "storage",
    "identity",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "oauth2": {
    "client_id": "577927281402-7u9m12099vcg0s904ra8n6gbhvct5061.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/drive.metadata.readonly"
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_side_panel": "side-panel.html"
  },
  "side_panel": {
    "default_path": "side-panel.html"
  }
}
